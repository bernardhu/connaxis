# Copy to targets.env and edit values if needed.
# Example target (edit for your environment):
# - connect address: 127.0.0.1:30001
# - host/SNI: example.test

TARGET_HOST=example.test
TLS_PORT=30001
SNI=example.test
SMOKE_CONNECT_HOST=127.0.0.1
TESTSSL_ADD_HOST=example.test:127.0.0.1
WSS_PATH=/

# 1=enabled, 0=disabled
ENABLE_WSS_UPGRADE_CHECK=1
RUN_SMOKE=1
RUN_TESTSSL=1
TESTSSL_STRICT=0
RUN_TLSFUZZER=0
RUN_BOGO=0
RUN_TLSANVIL=0

# Optional command hooks for advanced protocol suites.
# When RUN_TLSFUZZER=1 / RUN_BOGO=1:
# - empty command => stage is marked SKIPPED
# - non-empty command => executed with TARGET_HOST/TLS_PORT/SNI/OUT_DIR exported
# - command exit 3 => stage is marked N/A
TLSFUZZER_CMD=
BOGO_CMD=
TLSANVIL_CMD=

# Example:
# RUN_BOGO=1
# BOGO_CMD='bash ./bogo/run_remote.sh'
# (optional overrides)
# BOGO_SSH_HOST=root@127.0.0.1
# BOGO_TLS_ENGINE=ktls
# BOGO_TEST_PATTERN='*-TLS12;*-TLS13;TLS13-*'
# BOGO_SKIP_PATTERN='*-DTLS-*;*-QUIC-*;...'

# Optional overrides
DOCKER_TESTSSL_IMAGE=drwetter/testssl.sh:latest
TESTSSL_OPTS=--fast --sneaky
TLSFUZZER_TIMEOUT_SEC=1800
BOGO_TIMEOUT_SEC=1800
TLSANVIL_TIMEOUT_SEC=1800
